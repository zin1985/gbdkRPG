+static void battle_prepare_player_turn_ui(void) {
+    battle_hide_window_and_reset_scroll();
+    draw_battle_frame();
+    show_battle_party_icons();
+    show_battle_enemy_sprites();
+    battle_move_command_cursor_obj();
+    battle_set_message_dirty("");
+    battle_update_dirty();
+}
