+static UINT8 step_toward_u8(UINT8 current, UINT8 target, UINT8 step) {
+    UINT8 delta;
+    if (current < target) {
+        delta = (UINT8)(target - current);
+        return (UINT8)(current + ((delta < step) ? delta : step));
+    }
+    if (current > target) {
+        delta = (UINT8)(current - target);
+        return (UINT8)(current - ((delta < step) ? delta : step));
+    }
+    return current;
+}
