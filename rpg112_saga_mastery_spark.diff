++static void u16_to_dec3(UINT16 value, char *out) {
++    UINT16 hundreds;
++    UINT8 tens;
++    UINT8 ones;
++    UINT8 i = 0u;
++
++    if (value > PLAYER_HP_MP_MAX) value = PLAYER_HP_MP_MAX;
++
++    hundreds = value / 100u;
++    tens = (UINT8)((value / 10u) % 10u);
++    ones = (UINT8)(value % 10u);
++
++    if (hundreds != 0u) {
++        out[i++] = (char)('0' + (UINT8)hundreds);
++        out[i++] = (char)('0' + tens);
++    } else if (tens != 0u) {
++        out[i++] = (char)('0' + tens);
++    }
++    out[i++] = (char)('0' + ones);
++    out[i] = '\0';
++}
