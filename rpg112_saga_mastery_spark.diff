+        if (battle_enemy_count == 1u) {
+            x = 72u;
+        } else if (battle_enemy_count == 2u) {
+            x = (UINT8)(56u + (UINT8)(i * 40u));
+        } else {
+            x = (UINT8)(36u + (UINT8)(i * 40u));
+        }
+
+        show_one_battle_enemy_sprite(base, x, BATTLE_ENEMY_SPRITE_Y, battle_enemy_sprite_kinds[i]);
+    }
