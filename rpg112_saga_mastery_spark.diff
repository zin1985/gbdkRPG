++static void u8_to_dec(UINT8 value, char *out) {
++    UINT8 hundreds;
++    UINT8 tens;
++    UINT8 ones;
++    UINT8 i = 0u;
++
++    hundreds = value / 100u;
++    tens = (value / 10u) % 10u;
++    ones = value % 10u;
++
++    if (hundreds != 0u) {
++        out[i++] = (char)('0' + hundreds);
++        out[i++] = (char)('0' + tens);
++    } else if (tens != 0u) {
++        out[i++] = (char)('0' + tens);
++    }
++    out[i++] = (char)('0' + ones);
++    out[i] = '\0';
++}
