++
++    n = charUFT8toUTF16(&utf16, pUTF8);
++    if (n == 0) return NULL;
++
++    if (h2z) {
++        utf16 = utf16_HantoZen(utf16);
++    }
++
++    getFontDataByUTF16(fontdata, utf16);
++    rotateToRight(fontdata);
