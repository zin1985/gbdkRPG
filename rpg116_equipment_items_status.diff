+static void inventory_u8_to_dec(UINT8 value, char *out) BANKED {
+    UINT8 i;
+
+    i = 0u;
+    if (value >= 10u) out[i++] = (char)('0' + (value / 10u));
+    out[i++] = (char)('0' + (value % 10u));
+    out[i] = '\0';
+}
