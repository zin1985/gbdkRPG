+static void party_init_member(UINT8 id, const char *name, UINT16 hp, UINT16 mp,
+                              UINT8 atk, UINT8 def, UINT8 skill, UINT8 heal,
+                              UINT8 agi, UINT8 sprite_tile_offset) {
+    if (id >= PARTY_ROSTER_COUNT) return;
+
+    party_roster[id].name = name;
+    party_roster[id].max_hp = hp;
+    party_roster[id].hp = hp;
+    party_roster[id].max_mp = mp;
+    party_roster[id].mp = mp;
+    party_roster[id].attack = atk;
+    party_roster[id].defense = def;
+    party_roster[id].skill_power = skill;
+    party_roster[id].heal_power = heal;
+    party_roster[id].agility = agi;
+    party_roster[id].sprite_tile_offset = sprite_tile_offset;
+}
+
+static void party_init_roster_defaults(void) {
+    party_active_slots[0] = PARTY_MEMBER_HERO;
+    party_active_slots[1] = PARTY_MEMBER_PRIEST;
+    party_active_slots[2] = PARTY_MEMBER_MAGE;
+
+    /* rpg100:
+     * Active party: ゆうしゃ / そうりょ / まほう.
+     * Reserve members are data-only for now; a later menu can call
+     * party_swap_active_with_reserve().
+     */
+    party_init_member(PARTY_MEMBER_HERO,    "ゆうしゃ", 38u, 24u, 7u, 3u, 8u, 10u, 8u, 0u);
+    party_init_member(PARTY_MEMBER_PRIEST,  "そうりょ", 24u, 18u, 4u, 3u, 4u, 14u, 5u, 8u);
+    party_init_member(PARTY_MEMBER_MAGE,    "まほう",   20u, 30u, 3u, 2u, 15u, 6u, 6u, 4u);
+
+    party_init_member(PARTY_MEMBER_WARRIOR, "せんし",   42u,  6u, 9u, 5u, 3u, 3u, 4u, 0u);
+    party_init_member(PARTY_MEMBER_ARCHER,  "かりうど", 30u, 12u, 7u, 3u, 6u, 5u, 9u, 4u);
+    party_init_member(PARTY_MEMBER_MONK,    "ぶとうか", 34u, 10u, 8u, 4u, 5u, 5u, 10u, 8u);
+}
+
+static void party_prepare_battle_members(void) {
+    PartyMember *hero;
+
+    hero = &party_roster[PARTY_MEMBER_HERO];
+
+    hero->max_hp = player_max_hp_stat;
+    hero->hp = player_max_hp_stat;
+    hero->max_mp = player_max_mp_stat;
+    hero->mp = player_max_mp_stat;
+    hero->attack = player_attack_stat;
+    hero->defense = player_defense_stat;
+    hero->skill_power = player_skill_power_stat;
+    hero->heal_power = player_heal_power_stat;
+    hero->agility = player_agility_stat;
+}
+
+static UINT8 party_get_active_member_id(UINT8 active_slot) {
+    if (active_slot >= PARTY_ACTIVE_COUNT) return PARTY_MEMBER_HERO;
+    return party_active_slots[active_slot];
+}
+
+static PartyMember *party_get_active_member(UINT8 active_slot) {
+    UINT8 member_id;
+
+    if (active_slot >= PARTY_ACTIVE_COUNT) return 0;
+
+    member_id = party_active_slots[active_slot];
+    if (member_id >= PARTY_ROSTER_COUNT) return 0;
+
+    return &party_roster[member_id];
+}
+
+static void party_sync_hero_from_player_battle(void) {
+    PartyMember *hero;
+
+    hero = &party_roster[PARTY_MEMBER_HERO];
+    hero->max_hp = player_battle.max_hp;
+    hero->hp = player_battle.hp;
+    hero->max_mp = player_battle.max_mp;
+    hero->mp = player_battle.mp;
+    hero->attack = player_battle.attack;
+    hero->defense = player_battle.defense;
+    hero->skill_power = player_battle.skill_power;
+    hero->heal_power = player_battle.heal_power;
+    hero->agility = player_battle.agility;
+}
+
+static void party_sync_player_battle_from_hero(void) {
+    PartyMember *hero;
+
+    hero = &party_roster[PARTY_MEMBER_HERO];
+    player_battle.max_hp = hero->max_hp;
+    player_battle.hp = hero->hp;
+    player_battle.max_mp = hero->max_mp;
+    player_battle.mp = hero->mp;
+    player_battle.attack = hero->attack;
+    player_battle.defense = hero->defense;
+    player_battle.skill_power = hero->skill_power;
+    player_battle.heal_power = hero->heal_power;
+    player_battle.agility = hero->agility;
+}
+
+static UINT8 party_active_alive_count(void) {
+    UINT8 i;
+    UINT8 count;
+    PartyMember *member;
+
+    count = 0u;
+    for (i = 0u; i < PARTY_ACTIVE_COUNT; i++) {
+        member = party_get_active_member(i);
+        if (member != 0 && member->hp > 0u) count++;
+    }
+    return count;
+}
+
+static UINT8 party_choose_random_alive_active_slot(void) {
+    UINT8 alive_count;
+    UINT8 pick;
+    UINT8 i;
+    PartyMember *member;
+
+    alive_count = party_active_alive_count();
+    if (alive_count == 0u) return 0u;
+
+    pick = (UINT8)(random_u8() % alive_count);
+
+    for (i = 0u; i < PARTY_ACTIVE_COUNT; i++) {
+        member = party_get_active_member(i);
+        if (member != 0 && member->hp > 0u) {
+            if (pick == 0u) return i;
+            pick--;
+        }
+    }
+
+    return 0u;
+}
+
+static void party_member_to_fighter(const PartyMember *member, Fighter *out) {
+    if (member == 0 || out == 0) return;
+
+    out->name = member->name;
+    out->max_hp = member->max_hp;
+    out->hp = member->hp;
+    out->max_mp = member->max_mp;
+    out->mp = member->mp;
+    out->attack = member->attack;
+    out->defense = member->defense;
+    out->skill_power = member->skill_power;
+    out->heal_power = member->heal_power;
+    out->agility = member->agility;
+}
+
+static UINT8 party_swap_active_with_reserve(UINT8 active_slot, UINT8 reserve_member_id) {
+    UINT8 i;
+    UINT8 old_member;
+
+    if (active_slot >= PARTY_ACTIVE_COUNT) return 0u;
+    if (reserve_member_id >= PARTY_ROSTER_COUNT) return 0u;
+
+    for (i = 0u; i < PARTY_ACTIVE_COUNT; i++) {
+        if (party_active_slots[i] == reserve_member_id) return 0u;
+    }
+
+    old_member = party_active_slots[active_slot];
+    party_active_slots[active_slot] = reserve_member_id;
+
+    /* keep hero/player_battle in sync if the hero slot was touched */
+    if (old_member == PARTY_MEMBER_HERO || reserve_member_id == PARTY_MEMBER_HERO) {
+        party_sync_player_battle_from_hero();
+    }
+
+    return 1u;
+}
